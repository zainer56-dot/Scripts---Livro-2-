while_read_outfile_FD_IN_AND_OUT() {

    [[ ! -r "$INFILE" ]] && {
        print "ERRO: não é possível ler $INFILE" >&2
        return 1
    }

    : > "$OUTFILE"

    # Abrir FD 3 para leitura
    exec 3< "$INFILE"

    # Salvar stdout e redirecionar para OUTFILE
    exec 4>&1
    exec 1> "$OUTFILE"

    while IFS= read -r LINE <&3
    do
        print -- "$LINE"
    done

    # Restaurar stdout e fechar FDs
    exec 1>&4
    exec 4>&-
    exec 3<&-

    return 0
}
