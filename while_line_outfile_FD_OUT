while_line_outfile_FD_OUT() {

    [[ ! -r "$INFILE" ]] && {
        print "ERRO: não é possível ler $INFILE" >&2
        return 1
    }

    : > "$OUTFILE"

    # Salvar stdout e redirecionar para OUTFILE
    exec 4>&1
    exec 1> "$OUTFILE"

    # Leitura correta linha a linha
    while IFS= read -r LINE
    do
        print -- "$LINE"
    done < "$INFILE"

    # Restaurar stdout e fechar FD
    exec 1>&4
    exec 4>&-

    return 0
}
