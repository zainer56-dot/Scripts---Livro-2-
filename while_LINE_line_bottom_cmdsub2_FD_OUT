while_LINE_line_bottom_cmdsub2_FD_OUT() {

    [[ ! -r "$INFILE" ]] && {
        print "ERRO: não é possível ler $INFILE" >&2
        return 1
    }

    : > "$OUTFILE"

    exec 4>&1
    exec 1> "$OUTFILE"

    while IFS= read -r LINE
    do
        print -- "$LINE"
    done < "$INFILE"

    exec 1>&4
    exec 4>&-

    return 0
}
